# ═══════════════════════════════════════════════════════════════════════════════
# AI Orchestrator - .gitignore
# ═══════════════════════════════════════════════════════════════════════════════
# SECURITY NOTICE:
#   This file prevents accidental commits of sensitive data.
#   Always review before committing new file types.
# ═══════════════════════════════════════════════════════════════════════════════

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# ═══════════════════════════════════════════════════════════════════════════════
# SECURITY: Environment / Secrets (NEVER commit these!)
# ═══════════════════════════════════════════════════════════════════════════════
.env
.env.*
!.env.example  # Keep the template
*.env
secrets.json
secrets.yaml
secrets.yml
*.key
*.pem
*.p12
*.pfx
*.crt
*.cer

# ═══════════════════════════════════════════════════════════════════════════════
# SECURITY: Runtime data that may contain sensitive info
# ═══════════════════════════════════════════════════════════════════════════════
~/.orchestrator_cache/
.orchestrator/
.orchestrator_cache/
*.db
*.db-shm
*.db-wal
.events/
cache/

# ═══════════════════════════════════════════════════════════════════════════════
# Generated outputs (may contain API responses with sensitive data)
# ═══════════════════════════════════════════════════════════════════════════════
outputs/
results/
sandbox/
temp/
tmp/

# Analysis reports (generated output)
ANALYSIS_REPORT.md
analysis_report*.md

# ═══════════════════════════════════════════════════════════════════════════════
# Git worktrees
# ═══════════════════════════════════════════════════════════════════════════════
.claude/worktrees/

# ═══════════════════════════════════════════════════════════════════════════════
# IDE
# ═══════════════════════════════════════════════════════════════════════════════
.vscode/
.idea/
*.swp
*.swo
*.sublime-*

# ═══════════════════════════════════════════════════════════════════════════════
# OS
# ═══════════════════════════════════════════════════════════════════════════════
.DS_Store
Thumbs.db
desktop.ini

# ═══════════════════════════════════════════════════════════════════════════════
# Logs (may contain sensitive data)
# ═══════════════════════════════════════════════════════════════════════════════
*.log
logs/
log/

# ═══════════════════════════════════════════════════════════════════════════════
# pytest / coverage
# ═══════════════════════════════════════════════════════════════════════════════
.pytest_cache/
.coverage
htmlcov/
coverage_html/
.tox/

# ═══════════════════════════════════════════════════════════════════════════════
# Distribution
# ═══════════════════════════════════════════════════════════════════════════════
*.whl
*.tar.gz
MANIFEST

# ═══════════════════════════════════════════════════════════════════════════════
# Node.js (for scaffold projects)
# ═══════════════════════════════════════════════════════════════════════════════
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ═══════════════════════════════════════════════════════════════════════════════
# Miscellaneous
# ═══════════════════════════════════════════════════════════════════════════════
APIS.txt
nul
*.bak
*.backup
*~
.aider*
